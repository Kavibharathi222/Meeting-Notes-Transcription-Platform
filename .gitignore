# ═══════════════════════════════════════════
#  Fireflies Clone — .gitignore
#  Covers: Next.js frontend + FastAPI backend
# ═══════════════════════════════════════════

# ── DEPENDENCIES ────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── NEXT.JS BUILD OUTPUT ─────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/.turbo/

# ── NEXT.JS CACHE ────────────────────────────
frontend/.next/cache/
frontend/.eslintcache

# ── ENVIRONMENT FILES ───────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local
frontend/.env.production
frontend/.env.development
backend/.env
backend/.env.local

# ── PYTHON / FASTAPI ─────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# Python distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# ── DATABASE FILES ───────────────────────────
*.sqlite
*.sqlite3
backend/*.sqlite
backend/*.sqlite3

# ── AUDIO / MEDIA FILES ──────────────────────
# Comment out if you want to include sample audio
*.wav
*.mp3
*.mp4
*.ogg
*.flac
# Keep sample.wav for demo purposes — uncomment below to include it:
# !frontend/public/sample.wav

# ── LOGS ─────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
uvicorn.log

# ── TESTING ──────────────────────────────────
coverage/
*.lcov
.nyc_output/
htmlcov/
.pytest_cache/
.coverage

# ── EDITOR / IDE ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── OS FILES ─────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ── VERCEL / DEPLOYMENT ───────────────────────
.vercel
.netlify

# ── MISC ──────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
